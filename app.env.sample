# minarca - app.env.sample
# Copy to app.env and adjust values before starting the stack.

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# Admin credentials
APP_ADMIN_USER=administrator
APP_ADMIN_PASS=changeme_admin_password

# Branding
APP_ORG_NAME=Minarca Server
